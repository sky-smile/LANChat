# LANChat 环境变量配置

# 数据库配置
DATABASE_URL=postgres://lanchat:lanchat123@localhost:5432/lanchat

# Redis 配置
REDIS_URL=redis://localhost:6379

# JWT 密钥（请在生产环境使用强密钥）
JWT_SECRET=your_jwt_secret_key_here

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# 日志级别
RUST_LOG=info,lanchat_api=debug

# 文件存储路径
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600
